<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - moja aplikacja platformy ASP.NET</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("CoffeeApp", "Dashboard", "Home", new { area = "" }, new { @class = "navbar-brand" }) @* Możesz zmienić "Nazwa aplikacji" na "CoffeeApp" i niech prowadzi do Dashboard *@
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Przełącz nawigację" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    @* Link do strony z logo *@
                    <li>@Html.ActionLink("Start", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    @* Link do panelu zarządzania (Twoja główna strona z linkami CRUD) *@
                    <li>@Html.ActionLink("Panel Zarządzania", "Dashboard", "Home", new { area = "" }, new { @class = "nav-link" })</li>

                    @* Linki do sekcji CRUD *@
                    <li>@Html.ActionLink("Kraje", "Index", "Countries", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Miasta", "Index", "Cities", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Ziarna Kawy", "Index", "CoffeeBeans", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Palarnie", "Index", "Roasters", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Kawy (Produkty)", "Index", "Coffees", new { area = "" }, new { @class = "nav-link" })</li>

                    @* Opcjonalnie: możesz usunąć te, jeśli nie są potrzebne do projektu na 3.0 *@
                    @* <li>@Html.ActionLink("Informacje", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li> *@
                    @* <li>@Html.ActionLink("Kontakt", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li> *@
                </ul>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Moja aplikacja ASP.NET</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>