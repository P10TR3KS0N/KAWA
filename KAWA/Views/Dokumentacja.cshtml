                <strong>Relacje:</strong>
                <ul>
                    <li><strong>Country</strong>: Country (wielu-do-jednego)</li>
                    <li><strong>Roasters</strong>: ICollection&lt;Roaster&gt; (1-do-wielu)</li>
                </ul>
            </div>
        </div>

        <div class="model-box">
            <h3>CoffeeBean (Ziarno kawy)</h3>
            <div class="property">
                <span class="prop-name">Id</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[Key]</div>
            </div>
            <div class="property">
                <span class="prop-name">Name</span>: <span class="prop-type">string</span>
                <div class="prop-attr">[Required], [StringLength(100)], [Display(Name = "Nazwa Ziarna")]</div>
            </div>
            <div class="property">
                <span class="prop-name">OriginCountryId</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[ForeignKey("OriginCountry")]</div>
            </div>
            <div class="relation">
                <strong>Relacje:</strong>
                <ul>
                    <li><strong>OriginCountry</strong>: Country (wielu-do-jednego)</li>
                    <li><strong>Coffees</strong>: ICollection&lt;Coffee&gt; (1-do-wielu)</li>
                </ul>
            </div>
        </div>

        <div class="model-box">
            <h3>Roaster (Palarnia)</h3>
            <div class="property">
                <span class="prop-name">Id</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[Key]</div>
            </div>
            <div class="property">
                <span class="prop-name">Name</span>: <span class="prop-type">string</span>
                <div class="prop-attr">[Required], [StringLength(150)], [Display(Name = "Nazwa Palarni")]</div>
            </div>
            <div class="property">
                <span class="prop-name">CityId</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[ForeignKey("City")]</div>
            </div>
            <div class="relation">
                <strong>Relacje:</strong>
                <ul>
                    <li><strong>City</strong>: City (wielu-do-jednego)</li>
                    <li><strong>Coffees</strong>: ICollection&lt;Coffee&gt; (1-do-wielu)</li>
                </ul>
            </div>
        </div>

        <div class="model-box">
            <h3>Coffee (Kawa)</h3>
            <div class="property">
                <span class="prop-name">Id</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[Key]</div>
            </div>
            <div class="property">
                <span class="prop-name">Name</span>: <span class="prop-type">string</span>
                <div class="prop-attr">[Required], [StringLength(200)], [Display(Name = "Nazwa Kawy")]</div>
            </div>
            <div class="property">
                <span class="prop-name">RoastLevel</span>: <span class="prop-type">string</span>
                <div class="prop-attr">[Required], [StringLength(50)]</div>
            </div>
            <div class="property">
                <span class="prop-name">Price</span>: <span class="prop-type">decimal</span>
                <div class="prop-attr">[Required], [Range(0.01, 1000.00)], [DataType(DataType.Currency)]</div>
            </div>
            <div class="property">
                <span class="prop-name">BeanId</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[ForeignKey("Bean")]</div>
            </div>
            <div class="property">
                <span class="prop-name">RoasterId</span>: <span class="prop-type">int</span>
                <div class="prop-attr">[ForeignKey("Roaster")]</div>
            </div>
            <div class="relation">
                <strong>Relacje:</strong>
                <ul>
                    <li><strong>Bean</strong>: CoffeeBean (wielu-do-jednego)</li>
                    <li><strong>Roaster</strong>: Roaster (wielu-do-jednego)</li>
                </ul>
            </div>
        </div>
    </div>

